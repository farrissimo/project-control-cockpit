{
  "name": "pcc-cockpit",
  "version": "0.0.1",
  "description": "PCC - local-first project control cockpit (desktop app). Consumes the .cockpit/ file bridge; drives Claude Code as the worker.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:scripts": "playwright test tests/scripts",
    "test:external-smoke": "playwright test -c playwright.external.config.js",
    "postinstall": "node tools/install-git-hooks.js"
  },
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "electron": "^33.2.0"
  }
}
