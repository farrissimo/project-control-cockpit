# Non-canonical local restore points created by scripts/backup-protected-files.ps1.
# These are disposable snapshots, not project truth - see docs/STATE_MODEL.md.
.cockpit/backups/

# Ephemeral runtime lock for scripts/codex-verify-watcher.ps1 (pcc-brr5-004).
# Not project truth; recreated/cleared automatically each cycle.
.cockpit/state/codex-watcher.lock

# Write-ahead journal for the paired task/project-state write (Part 7 I1). Exists only
# momentarily during a paired write; a crash-leftover is replayed+cleared on the next
# writer run. Transient recovery state, never committed.
.cockpit/state/.state-update.journal.json

# Transient hand-off inbox: bootstrap-project.ps1 drops new project paths here and
# the app consumes+clears them. Runtime bridge, not project truth.
.cockpit/state/scaffolded-inbox.json

# First-class chat history (docs/CHAT_RECALL_SPEC.md): per-chat AI summaries +
# transcript mirror the app writes on demand. Local-first record (backed up by
# backup-protected-files.ps1), greppable for recall — but not committed repo truth.
.cockpit/chats/

# Local, on-demand exports of chat transcripts (personal content; never committed).
.cockpit/chat-export/

# Generated Owner Control Board dashboard (scripts/generate-dashboard.ps1,
# pcc-pathD-001). Derived output regenerated from .cockpit/ state; not source.
dashboard/index.html

# Generated release-gate evidence (scripts/run-release-gate.ps1). A machine-readable
# record of one exact-SHA gate run; regenerated on demand, not committed repo truth.
# (If it were committed, generating it would dirty the tree and the gate would fail
# itself.)
.cockpit/evidence/

# Electron dependencies for the desktop app (app/). Reinstalled via npm install; not source.
app/node_modules/

# Generated verification output written by scripts/verify-work.ps1 (-WriteFile). Not source.
app/last-verification.txt

# Test tooling — Playwright artifacts (match at repo root or under app/).
app/node_modules/
test-results/
playwright-report/

# Ephemeral scratch for scripts/run-mutation-proof.ps1 (isolated mutation copies).
# Nested under app/ so node_modules resolves upward; created + deleted per run. Not source.
app/.pcc-mut-tmp/

# Full-project archive (a ~176MB backup snapshot of the repo dir, not source). It is
# created by an external/backup step, not by any code in this repo — ignored so it can
# never dirty the tree or be committed. Delete it manually if unwanted.
/ProjectControlCockpit.zip

# Packaged installer output (electron-builder)
/dist/

# Claude Code personal/local settings (machine-specific; never shared)
.claude/settings.local.json

# App-level error log (app/error-log.js): a local, per-machine diagnostic trace of
# otherwise-swallowed app failures, surfaced by doctor.ps1. Runtime output with local
# paths/stack traces — never committed repo truth (unlike the workflow routing-log).
.cockpit/logs/app-error.log

# Secrets — never commit real credentials (AGENTS.md security rule: "Env is
# git-ignored"). This block MAKES that promise real: env files and common
# key/cert formats can't be staged, so a worker or a spawned project (this file
# travels via bootstrap-project.ps1) can't silently leak a secret into git.
# .env.example is a deliberately-committed template, so it stays tracked.
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
