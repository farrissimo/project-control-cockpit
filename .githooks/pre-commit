#!/bin/sh
# PCC pre-commit — TESTS ARE OPT-IN (owner rule, 2026-07-08).
#
# The app must NEVER be launched for testing by an automated action without the
# owner's explicit approval. So a plain `git commit` does NOT run the suite and
# does NOT launch the app — it just commits.
#
# The owner approves a test run per-commit by opting in:
#
#     PCC_RUN_TESTS=1 git commit ...
#
# (This hook used to auto-run the suite on every app/ commit. That automatic
# launch is exactly what made the app "start itself", so it was removed. Tests
# still exist and are valuable — they just run when you say so, not on their own.)

if [ "$PCC_RUN_TESTS" != "1" ]; then
  echo "[pcc] Tests are opt-in — not launching the app. Approve a run with: PCC_RUN_TESTS=1 git commit ..."
  exit 0
fi

echo "[pcc] PCC_RUN_TESTS=1 — approved by owner: running test suite (npm test)…"

# Clear only THIS project's throwaway test apps (user-data-dir contains 'pcc-test-').
# Never a blanket `taskkill electron.exe` — that would kill the owner's real app or
# any other Electron app that happens to be open.
clear_test_electron() {
  powershell -NoProfile -Command "Get-CimInstance Win32_Process | Where-Object { \$_.Name -eq 'electron.exe' -and \$_.CommandLine -match 'pcc-test-' } | ForEach-Object { Stop-Process -Id \$_.ProcessId -Force -ErrorAction SilentlyContinue }" >/dev/null 2>&1 || true
}

clear_test_electron
npm test --prefix app
if [ $? -ne 0 ]; then
  # A real failure fails twice; the known collection flake passes on retry. Retry
  # ONCE (after clearing strays) rather than block a good commit on a flake.
  echo ""
  echo "[pcc] Test run failed — clearing stray test apps and retrying once (known Playwright collection flake)…"
  clear_test_electron
  npm test --prefix app
  if [ $? -ne 0 ]; then
    echo ""
    echo "[pcc] TESTS FAILED (after retry) — commit blocked."
    echo "      Fix the failures, or commit without tests (the default — just don't set PCC_RUN_TESTS)."
    exit 1
  fi
fi
echo "[pcc] Tests passed — proceeding with commit."
exit 0
