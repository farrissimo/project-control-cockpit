{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "canonical-constraints.schema.json",
  "title": "PCC canonical-constraints registry — binding cross-cutting requirements, cited not restated",
  "type": "object",
  "additionalProperties": false,
  "required": ["constraints_id", "title", "plain_language", "applies_to_tiers", "exempt_tiers", "default_on", "constraints"],
  "properties": {
    "constraints_id": { "const": "canonical-constraints-v1" },
    "title": { "type": "string", "minLength": 1 },
    "plain_language": { "type": "object" },
    "applies_to_tiers": { "type": "array", "items": { "enum": ["T0", "T1", "T2", "T3", "T4"] } },
    "exempt_tiers": { "type": "array", "items": { "enum": ["T0", "T1", "T2", "T3", "T4"] } },
    "default_on": { "type": "boolean" },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "source_path", "section", "requirement_key", "statement", "statement_sha256", "required_evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 3 },
          "label": { "type": "string", "minLength": 3 },
          "source_path": { "type": "string", "minLength": 3 },
          "section": { "type": ["string", "null"] },
          "requirement_key": { "type": "string", "minLength": 3 },
          "statement": { "type": "string", "minLength": 10 },
          "statement_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "required_evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "not_proven": { "type": "string" }
  }
}
